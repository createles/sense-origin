<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <nav>
      <h1><a href="/">Sense Coffee</a></h1>
      <ul>
        <li><a href="/catalog">Browse</a></li>

        <!-- check if currently admin -->
        <% if (isAdmin) { %>
        <li><a href="/manage">Manage inventory</a></li> <!-- show link to manage page -->
        <li>
          <form action="/logout" method="POST" style="display:inline;">
            <button type="submit" class="logout-btn">
              Logout
            </button>
          </form>
        </li>
        <% } else { %>
          <li><a href="/login">Admin Login</a></li> <!-- show link to login page -->
        <% } %>
      </ul>
    </nav>
  </header>
  
  <main>